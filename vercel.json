{
  "version": 2,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/login"
    },
    {
      "source": "/history",
      "destination": "/history"
    },
    {
      "source": "/:slug",
      "destination": "/api/resolve?slug=:slug"
    }
  ],
  "redirects": [
    {
      "source": "/shorten",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
